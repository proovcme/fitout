[Unit]
Description=FITOUT player profiles and saves
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
Environment=FITOUT_PORT=4188
Environment=FITOUT_DATA_DIR=/var/lib/fitout
ExecStart=/usr/bin/python3 /opt/fitout-save/server.py
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/fitout

[Install]
WantedBy=multi-user.target
